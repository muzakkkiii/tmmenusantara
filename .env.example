APP_NAME="TM Menusantara"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://menusantara.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=single
LOG_LEVEL=debug

# Default: SQLite (paling mudah untuk dijalankan di PC)
DB_CONNECTION=sqlite
# DB_DATABASE=/path/absolut/ke/database.sqlite

# Jika ingin MySQL (mis. Hostinger), ganti baris di atas jadi:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=menusantara
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ---- Mail (notifikasi lead/donasi ke admin) ----
# Default "log": email ditulis ke storage/logs (aman untuk uji lokal).
# Untuk kirim sungguhan, isi SMTP di bawah lalu ganti MAIL_MAILER=smtp
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@menusantara.org"
MAIL_FROM_NAME="TM Menusantara"

# CATATAN PRODUCTION: set APP_ENV=production, APP_DEBUG=false, APP_URL=https://domainanda
